<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.space.knowledge.mapper.GradeMapper">
    <resultMap id="BaseResultMap" type="Grade">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="sort_order" property="sortOrder"/>
    </resultMap>
    <select id="selectAll" resultMap="BaseResultMap">SELECT * FROM grades ORDER BY sort_order</select>
    <select id="selectById" resultMap="BaseResultMap">SELECT * FROM grades WHERE id=#{id}</select>
</mapper>
